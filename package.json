{
  "name": "rose-ticket",
  "version": "1.0.0",
  "private": true,
  "description": "Rose Ticket - Discord private-thread ticket system with dashboard",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @rose-ticket/db prisma:generate",
    "db:migrate": "pnpm --filter @rose-ticket/db prisma:migrate",
    "db:studio": "pnpm --filter @rose-ticket/db prisma:studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/node": "^20.14.10",
    "eslint": "^9.6.0",
    "prettier": "^3.3.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}

# Shared
NODE_ENV=development
# Local Postgres example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rose_ticket
# Railway + Supabase: use the Supabase Session pooler URL in Railway variables.
# Encode special characters in passwords, for example @ -> %40.
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Discord application
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_PUBLIC_KEY=your_discord_public_key
DISCORD_REDIRECT_URI=http://localhost:4000/auth/callback

# API
API_PORT=4000
SESSION_SECRET=replace_with_a_long_random_secret
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:4000

# Bot
BOT_DEV_GUILD_ID=
DISCORD_ENABLE_PRIVILEGED_INTENTS=false
AUTO_CLOSE_INTERVAL_MS=300000
TRANSCRIPT_MAX_MESSAGES=5000

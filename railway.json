{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm railway:bot:build"
  },
  "deploy": {
    "preDeployCommand": "pnpm railway:bot:predeploy",
    "startCommand": "pnpm railway:bot:start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
